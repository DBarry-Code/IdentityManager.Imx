{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "iqc",
  "sourceRoot": "projects/iqc/src",
  "implicitDependencies": [
    "qer"
  ],
  "projectType": "library",
  "prefix": "imx",
  "generators": {
    "@schematics/angular:component": {
      "style": "scss"
    }
  },
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:ng-packagr",
      "options": {
        "tsConfig": "projects/iqc/tsconfig.lib.json",
        "project": "projects/iqc/ng-package.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "projects/iqc/tsconfig.lib.prod.json"
        },
        "development": {
          "tsConfig": "projects/iqc/tsconfig.lib.json"
        },
        "remote-dev": {
          "tsConfig": "projects/iqc/tsconfig.lib.json"
        },
        "remote-qs": {
          "tsConfig": "projects/iqc/tsconfig.lib.json"
        }
      },
      "outputs": [
        "{workspaceRoot}/dist/iqc"
      ]
    },
    "test": {
      "executor": "@angular-devkit/build-angular:karma",
      "options": {
        "main": "projects/iqc/src/test.ts",
        "tsConfig": "projects/iqc/tsconfig.spec.json",
        "karmaConfig": "projects/iqc/karma.conf.js",
        "stylePreprocessorOptions": {
          "includePaths": [
            "./shared/assets",
            "./shared/scss",
            "./node_modules",
            "./node_modules/@elemental-ui/cadence-icon",
            "./node_modules/@elemental-ui/core"
          ]
        }
      }
    },
    "lint": {
      "executor": "@angular-devkit/build-angular:tslint",
      "options": {
        "tsConfig": [
          "projects/iqc/tsconfig.lib.json",
          "projects/iqc/tsconfig.spec.json"
        ],
        "exclude": [
          "**/node_modules/**",
          "**/*.spec.ts",
          "**/*.json"
        ]
      }
    }
  }
}