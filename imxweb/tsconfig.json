{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": "./",
    "outDir": "./dist/out-tsc",
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "strictNullChecks": true,
    "noImplicitOverride": false,
    "esModuleInterop": true,
    "noPropertyAccessFromIndexSignature": false,
    "noImplicitReturns": false,
    "resolveJsonModule": true,
    "allowJs": true,
    "paths": {
      "aad": ["dist/aad"],
      "aad/*": ["dist/aad/*"],
      "aob": ["dist/aob"],
      "aob/*": ["dist/aob/*"],
      "apc": ["dist/apc"],
      "apc/*": ["dist/apc/*"],
      "att": ["dist/att"],
      "att/*": ["dist/att/*"],
      "cpl": ["dist/cpl"],
      "cpl/*": ["dist/cpl/*"],
      "dpr": ["dist/dpr"],
      "dpr/*": ["dist/dpr/*"],
      "hds": ["dist/hds"],
      "hds/*": ["dist/hds/*"],
      "iqc": ["dist/iqc"],
      "iqc/*": ["dist/iqc/*"],
      "olg": ["dist/olg"],
      "olg/*": ["dist/olg/*"],
      "o3t": ["dist/o3t"],
      "o3t/*": ["dist/o3t/*"],
      "pol": ["dist/pol"],
      "pol/*": ["dist/pol/*"],
      "qam": ["dist/qam"],
      "qam/*": ["dist/qam/*"],
      "qbm": ["dist/qbm"],
      "qbm/*": ["dist/qbm/*"],
      "qer": ["dist/qer"],
      "qer/*": ["dist/qer/*"],
      "rmb": ["dist/rmb"],
      "rmb/*": ["dist/rmb/*"],
      "rms": ["dist/rms"],
      "rms/*": ["dist/rms/*"],
      "rps": ["dist/rps"],
      "rps/*": ["dist/rps/*"],
      "sac": ["dist/sac"],
      "sac/*": ["dist/sac/*"],
      "tsb": ["dist/tsb"],
      "tsb/*": ["dist/tsb/*"],
    },
    "noFallthroughCasesInSwitch": true,
    "sourceMap": true,
    "declaration": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "target": "ES2024",
    "typeRoots": ["node_modules/@types", "node_modules/@angular/material", "node_modules/@elemental-ui/core"],
    "module": "ESNext",
    "lib": ["ES2024", "dom"]
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": false,
    "strictInputAccessModifiers": true,
    "strictTemplates": true,
    "strictNullInputTypes": false
  }
}
